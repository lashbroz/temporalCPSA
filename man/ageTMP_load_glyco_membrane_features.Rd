\name{ageTMP_load_glyco_membrane_features}
\alias{ageTMP_load_glyco_membrane_features}
\title{Load membrane glycopeptide annotation}
\usage{
ageTMP_load_glyco_membrane_features()
}
\value{
A data frame with \code{glycopeptide} and \code{membrane.loc} columns.
}
\description{
This documented package data source replaces the manuscript
\code{membrane_glycopeptide.RData} workspace for glycopeptide-level survival table
reproduction. It contains glycopeptides annotated as membrane-localized in the
original manuscript workflow.
}
